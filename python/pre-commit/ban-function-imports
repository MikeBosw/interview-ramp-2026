#!/usr/bin/env python3
"""Pre-commit hook that bans import statements inside function bodies.

Only inspects added lines from the staged diff, so pre-existing function-level
imports in unmodified code are never flagged.
"""

import ast
import re
import subprocess
import sys
from collections.abc import Callable


def _import_lines_inside_functions(source: str) -> dict[int, str]:
    """Returns {line_number: import text} for Import/ImportFrom nodes inside functions.

    Covers every line in the node's span (lineno..end_lineno), so continuation
    lines of multi-line imports are included.
    """
    try:
        tree = ast.parse(source)
    except SyntaxError:
        return {}
    source_lines = source.splitlines()
    result: dict[int, str] = {}
    for node in ast.walk(tree):
        if not isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
            continue
        for child in ast.walk(node):
            if not isinstance(child, (ast.Import, ast.ImportFrom)):
                continue
            end = child.end_lineno if child.end_lineno is not None else child.lineno
            for line_num in range(child.lineno, end + 1):
                if line_num <= len(source_lines):
                    result[line_num] = source_lines[line_num - 1].strip()
    return result


def _staged_contents(path: str) -> str:
    """Returns the staged (index) contents of a file."""
    result = subprocess.run(
        ['git', 'show', f':{path}'],
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout


def _added_lines_from_diff(diff_text: str) -> dict[str, set[int]]:
    """Parses unified diff and returns {file: set of added line numbers} for .py files under python/."""
    added: dict[str, set[int]] = {}
    current_file = ''
    current_line = 0
    for raw_line in diff_text.splitlines():
        if raw_line.startswith('+++ b/'):
            current_file = raw_line[6:]
            if not (current_file.startswith('python/') and current_file.endswith('.py')):
                current_file = ''
        elif raw_line.startswith('@@') and current_file:
            match = re.search(r'\+(\d+)', raw_line)
            if match:
                current_line = int(match.group(1)) - 1
        elif raw_line.startswith('+') and not raw_line.startswith('+++'):
            current_line += 1
            if current_file:
                added.setdefault(current_file, set()).add(current_line)
        elif raw_line.startswith(' '):
            current_line += 1
    return added


def find_violations(
    diff_text: str, read_source: Callable[[str], str],
) -> list[tuple[str, int, str]]:
    """Finds newly added import statements inside function bodies.

    Returns (file_path, line_number, line_content) tuples for each violation.
    """
    added_lines = _added_lines_from_diff(diff_text)
    violations: list[tuple[str, int, str]] = []
    for filepath, line_numbers in added_lines.items():
        source = read_source(filepath)
        import_lines = _import_lines_inside_functions(source)
        for line_num in sorted(line_numbers):
            if line_num in import_lines:
                violations.append((filepath, line_num, import_lines[line_num]))
    return violations


def main() -> None:
    result = subprocess.run(
        ['git', 'diff', '--cached', '--unified=0'],
        capture_output=True,
        text=True,
        check=True,
    )
    violations = find_violations(result.stdout, _staged_contents)
    if not violations:
        return
    print('imports inside functions are banned — move them to the top of the module or fix the circular import:')
    for filepath, line_num, content in violations:
        print(f'  {filepath}:{line_num}: {content}')
    sys.exit(1)


if __name__ == '__main__':
    main()
