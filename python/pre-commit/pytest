#!/usr/bin/env python3
"""Pre-commit hook that runs only the tests affected by staged changes.

Discovers tests colocated with workspace members (e.g. simplemind/microgpt/tests/).
"""

import os
import subprocess
import sys
from pathlib import Path


def _repo_root() -> Path:
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True,
        text=True,
        check=True,
    )
    return Path(result.stdout.strip())


def _staged_files() -> list[str]:
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only"],
        capture_output=True,
        text=True,
        check=True,
    )
    return [line for line in result.stdout.splitlines() if line]


def _find_workspace_test_dirs(repo_root: Path) -> dict[str, Path]:
    """Returns {prefix: tests_dir} for each directory under python/ that has a tests/ subdirectory."""
    result: dict[str, Path] = {}
    python_dir = repo_root / "python"
    for group in python_dir.iterdir():
        if not group.is_dir() or group.name.startswith("."):
            continue
        for member in group.iterdir():
            if not member.is_dir():
                continue
            tests_dir = member / "tests"
            if tests_dir.is_dir():
                prefix = f"python/{group.name}/{member.name}/"
                result[prefix] = tests_dir
    return result


def _triggered_test_dirs(staged: list[str], repo_root: Path) -> set[Path]:
    workspace_tests = _find_workspace_test_dirs(repo_root)
    triggered: set[Path] = set()
    for path in staged:
        for prefix, tests_dir in workspace_tests.items():
            if path.startswith(prefix):
                triggered.add(tests_dir)
    return triggered


def main() -> None:
    repo_root = _repo_root()
    venv_bin = repo_root / "python" / ".venv" / "bin"
    env = {**os.environ, "PATH": f"{venv_bin}:{os.environ.get('PATH', '')}"}
    staged = _staged_files()

    triggered = _triggered_test_dirs(staged, repo_root)
    if not triggered:
        sys.exit(0)

    os.chdir(repo_root / "python")
    sys.exit(subprocess.run(["pytest", *sorted(str(d) for d in triggered)], env=env).returncode)


if __name__ == "__main__":
    main()
